# ── Mode ──
# "local" for local development with MCP-Unity on same machine
# "pod" for remote RunPod deployment
RUN_MODE=local

# ── API Security ──
API_SECRET_KEY=change-me-to-a-strong-random-key

# ── HuggingFace (for model downloads) ──
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MCP-Unity ──
# Local mode: ws://localhost:8090/McpUnity
# Pod mode: wss://xxx.trycloudflare.com/McpUnity (via cloudflared tunnel)
MCP_UNITY_WS_URL=ws://localhost:8090/McpUnity

# ── vLLM endpoints ──
# Local: http://localhost:8000/v1
# Pod: https://PODID-8000.proxy.runpod.net/v1
VLLM_LLM_URL=http://localhost:8000/v1
VLLM_VISION_URL=http://localhost:8001/v1

# ── Embedding / Reranker ──
# Local: http://localhost:8002
# Pod: https://PODID-8002.proxy.runpod.net
EMBEDDING_URL=http://localhost:8002
RERANKER_URL=http://localhost:8003

# ── Qdrant ──
# Local: http://localhost:6333
# Pod: https://PODID-6333.proxy.runpod.net
QDRANT_URL=http://localhost:6333

# ── Pod connection (only needed if RUN_MODE=pod) ──
# POD_ID=your-pod-id-here
