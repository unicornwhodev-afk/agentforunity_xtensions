# AgentUnity — Configuration locale
# Copiez ce fichier en .env et adaptez les valeurs

# Mode: "local" ou "pod"
RUN_MODE=local

# API
API_SECRET_KEY=dev-key-change-me

# MCP-Unity (Unity Editor sur la même machine)
# Assurez-vous que le serveur MCP-Unity écoute sur ws://localhost:8090
MCP_UNITY_WS_URL=ws://localhost:8090/McpUnity

# vLLM (modèles locaux ou via pod)
VLLM_LLM_URL=http://localhost:8000/v1
VLLM_VISION_URL=http://localhost:8001/v1

# Embedding / Reranker
EMBEDDING_URL=http://localhost:8002
RERANKER_URL=http://localhost:8003

# Qdrant
QDRANT_URL=http://localhost:6333

# Pod connection (si RUN_MODE=pod)
# POD_ID=abc123def